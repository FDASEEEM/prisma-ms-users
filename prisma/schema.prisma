generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["users"]
}

model Colegio {
  id           String   @id @default(uuid()) @db.Uuid
  nombre       String
  direccion    String
  telefono     String?  @map("telefono")
  email        String   @unique @map("email")
  rut          String   @unique @map("rut")
  plan         String   @default("basic") @map("plan")
  fechaInicio  DateTime @default(now()) @map("fecha_inicio")
  fechaTermino DateTime? @map("fecha_termino")
  activo       Boolean  @default(true) @map("activo")
  createdAt    DateTime @default(now()) @map("creado_en")
  updatedAt    DateTime @updatedAt @map("actualizado_en")
  users        User[]

  @@schema("users")
  @@map("colegios")
}

model User {
  id              String       @id @default(uuid()) @db.Uuid
  supabaseUserId  String       @unique @map("id_supabase")
  email           String       @unique @map("correo")
  rut             String       @unique
  nombreCompleto  String       @map("nombre_completo")
  establecimiento String?      @map("establecimiento")
  phone           String?      @map("telefono")
  specialty       String?      @map("especialidad")
  position        String?      @map("cargo")
  active          Boolean      @default(true) @map("activo")
  createdAt       DateTime     @default(now()) @map("creado_en")
  updatedAt       DateTime     @updatedAt @map("actualizado_en")
  role            UserRole     @default(TEACHER) @map("rol")
  colegioId       String?      @map("colegio_id") @db.Uuid
  colegio         Colegio?     @relation(fields: [colegioId], references: [id], onDelete: SetNull)
  logs            LogUsuario[]

  @@index([colegioId])
  @@schema("users")
  @@map("usuarios")
}

model LogUsuario {
  id         String             @id @default(uuid()) @db.Uuid
  tipoEvento TipoEventoUsuario  @map("tipo_evento")
  userId     String?            @map("user_id") @db.Uuid
  ipOrigen   String?            @map("ip_origen")
  resultado  ResultadoOperacion @map("resultado")
  mensaje    String             @map("mensaje")
  fechaHora  DateTime           @default(now()) @map("fecha_hora")
  user       User?              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([fechaHora])
  @@schema("users")
  @@map("logs_usuarios")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  TEACHER

  @@schema("users")
}

enum TipoEventoUsuario {
  register
  login
  logout
  refresh
  profile_update
  colegio_create
  colegio_update
  colegio_deactivate
  admin_create
  admin_update
  admin_deactivate
  admin_reactivate
  admin_password_reset

  @@schema("users")
}

enum ResultadoOperacion {
  success
  failure

  @@schema("users")
}
