generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["users"]
}

model User {
  id              String       @id @default(uuid()) @db.Uuid
  supabaseUserId  String       @unique @map("id_supabase")
  email           String       @unique @map("correo")
  rut             String       @unique
  nombreCompleto  String       @map("nombre_completo")
  establecimiento String?      @map("establecimiento")
  phone           String?      @map("telefono")
  specialty       String?      @map("especialidad")
  position        String?      @map("cargo")
  active          Boolean      @default(true) @map("activo")
  createdAt       DateTime     @default(now()) @map("creado_en")
  updatedAt       DateTime     @updatedAt @map("actualizado_en")
  role            UserRole     @default(TEACHER) @map("rol")
  logs            LogUsuario[]

  @@schema("users")
  @@map("usuarios")
}

model LogUsuario {
  id         String             @id @default(uuid()) @db.Uuid
  tipoEvento TipoEventoUsuario  @map("tipo_evento")
  userId     String?            @map("user_id") @db.Uuid
  ipOrigen   String?            @map("ip_origen")
  resultado  ResultadoOperacion @map("resultado")
  mensaje    String             @map("mensaje")
  fechaHora  DateTime           @default(now()) @map("fecha_hora")
  user       User?              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([fechaHora])
  @@schema("users")
  @@map("logs_usuarios")
}

enum UserRole {
  ADMIN
  TEACHER

  @@schema("users")
}

enum TipoEventoUsuario {
  register
  login
  logout
  refresh
  profile_update

  @@schema("users")
}

enum ResultadoOperacion {
  success
  failure

  @@schema("users")
}
